{%- if request.page_type == 'product' -%}
  {%- assign og_title = product.title -%}
  {%- assign og_description = product.description | strip_html | truncatewords: 30 -%}
  {%- assign og_image = product.featured_image | image_url: width: 1200 -%}
{%- elsif request.page_type == 'article' -%}
  {%- assign og_title = article.title -%}
  {%- assign og_description = article.excerpt_or_content | strip_html | truncatewords: 30 -%}
  {%- assign og_image = article.image | image_url: width: 1200 -%}
{%- else -%}
  {%- assign og_title = page_title -%}
  {%- assign og_description = page_description -%}
  {%- assign og_image = settings.share_image | image_url: width: 1200 -%}
{%- endif -%}

<meta property="og:site_name" content="{{ shop.name }}">
<meta property="og:url" content="{{ canonical_url }}">
<meta property="og:title" content="{{ og_title | escape }}">
<meta property="og:type" content="{% if request.page_type == 'product' %}product{% elsif request.page_type == 'article' %}article{% else %}website{% endif %}">
{% if og_description != blank %}<meta property="og:description" content="{{ og_description | escape }}">{% endif %}
{% if og_image != blank %}<meta property="og:image" content="{{ og_image }}">{% endif %}

<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="{{ og_title | escape }}">
{% if og_description != blank %}<meta name="twitter:description" content="{{ og_description | escape }}">{% endif %}
