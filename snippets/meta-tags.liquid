{%- comment -%} ============================================
   GoPotty — Comprehensive SEO meta tags
   - Standard meta (description, robots, keywords)
   - Open Graph (Facebook, LinkedIn, etc.)
   - Twitter Card
   - Canonical + hreflang for international SEO
   - JSON-LD structured data: Organization, WebSite, Product, Article, BreadcrumbList
============================================ {%- endcomment -%}

{%- comment -%} Resolve page-specific values {%- endcomment -%}
{%- if request.page_type == 'product' -%}
  {%- assign seo_title = product.title -%}
  {%- assign seo_description = product.description | strip_html | truncatewords: 30 -%}
  {%- assign seo_image = product.featured_image | image_url: width: 1200 -%}
  {%- assign og_type = 'product' -%}
{%- elsif request.page_type == 'article' -%}
  {%- assign seo_title = article.title -%}
  {%- assign seo_description = article.excerpt_or_content | strip_html | truncatewords: 30 -%}
  {%- assign seo_image = article.image | image_url: width: 1200 -%}
  {%- assign og_type = 'article' -%}
{%- elsif request.page_type == 'collection' -%}
  {%- assign seo_title = collection.title -%}
  {%- assign seo_description = collection.description | default: collection.title | strip_html | truncatewords: 30 -%}
  {%- assign seo_image = collection.image | image_url: width: 1200 -%}
  {%- assign og_type = 'website' -%}
{%- elsif request.page_type == 'page' -%}
  {%- assign seo_title = page.title -%}
  {%- assign seo_description = page.content | strip_html | truncatewords: 30 -%}
  {%- assign og_type = 'website' -%}
{%- elsif request.page_type == 'blog' -%}
  {%- assign seo_title = blog.title -%}
  {%- assign seo_description = blog.title -%}
  {%- assign og_type = 'website' -%}
{%- elsif request.page_type == 'index' -%}
  {%- assign seo_title = shop.name -%}
  {%- assign seo_description = shop.description | default: 'The self-cleaning dog potty that automatically drains, collects and stores urine so you never have to clean it up again. Free shipping over $99.' -%}
  {%- assign og_type = 'website' -%}
{%- else -%}
  {%- assign seo_title = page_title -%}
  {%- assign seo_description = page_description | default: shop.description -%}
  {%- assign og_type = 'website' -%}
{%- endif -%}

{%- unless seo_image -%}
  {%- if settings.share_image != blank -%}
    {%- assign seo_image = settings.share_image | image_url: width: 1200 -%}
  {%- endif -%}
{%- endunless -%}

{%- comment -%} ====== STANDARD META ====== {%- endcomment -%}
<meta name="description" content="{{ seo_description | escape }}">
<meta name="author" content="{{ shop.name }}">
{%- if request.page_type == 'product' -%}
  {%- assign product_tags = product.tags | join: ', ' -%}
  {%- if product_tags != blank -%}<meta name="keywords" content="{{ product_tags | escape }}">{%- endif -%}
{%- endif -%}
<meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1">
<meta name="googlebot" content="index, follow">

{%- comment -%} ====== OPEN GRAPH ====== {%- endcomment -%}
<meta property="og:site_name" content="{{ shop.name }}">
<meta property="og:url" content="{{ canonical_url }}">
<meta property="og:title" content="{{ seo_title | escape }}">
<meta property="og:description" content="{{ seo_description | escape }}">
<meta property="og:type" content="{{ og_type }}">
<meta property="og:locale" content="{{ request.locale.iso_code | replace: '-', '_' | default: 'en_AU' }}">
{%- if seo_image -%}
<meta property="og:image" content="{{ seo_image }}">
<meta property="og:image:width" content="1200">
<meta property="og:image:height" content="630">
<meta property="og:image:alt" content="{{ seo_title | escape }}">
{%- endif -%}

{%- if request.page_type == 'product' -%}
<meta property="product:price:amount" content="{{ product.price | money_without_currency | strip_html }}">
<meta property="product:price:currency" content="{{ cart.currency.iso_code }}">
<meta property="product:availability" content="{% if product.available %}in stock{% else %}out of stock{% endif %}">
<meta property="product:brand" content="{{ shop.name }}">
{%- if product.vendor != blank %}<meta property="product:retailer_item_id" content="{{ product.id }}">{%- endif -%}
{%- endif -%}

{%- if request.page_type == 'article' -%}
<meta property="article:published_time" content="{{ article.published_at | date: '%Y-%m-%dT%H:%M:%SZ' }}">
<meta property="article:author" content="{{ article.author }}">
{%- for tag in article.tags -%}<meta property="article:tag" content="{{ tag | escape }}">{%- endfor -%}
{%- endif -%}

{%- comment -%} ====== TWITTER CARD ====== {%- endcomment -%}
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="{{ seo_title | escape }}">
<meta name="twitter:description" content="{{ seo_description | escape }}">
{%- if settings.twitter_handle != blank -%}
<meta name="twitter:site" content="{{ settings.twitter_handle }}">
<meta name="twitter:creator" content="{{ settings.twitter_handle }}">
{%- endif -%}
{%- if seo_image -%}<meta name="twitter:image" content="{{ seo_image }}">{%- endif -%}

{%- comment -%} ====== ALTERNATE / HREFLANG ====== {%- endcomment -%}
{%- if shop.published_locales.size > 1 -%}
  {%- for locale in shop.published_locales -%}
    <link rel="alternate" hreflang="{{ locale.iso_code }}" href="{{ request.origin }}{{ request.path }}{% if locale.primary == false %}?locale={{ locale.iso_code }}{% endif %}">
  {%- endfor -%}
  <link rel="alternate" hreflang="x-default" href="{{ request.origin }}{{ request.path }}">
{%- endif -%}

{%- comment -%} ====== JSON-LD STRUCTURED DATA ====== {%- endcomment -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": {{ shop.name | json }},
  "url": {{ shop.url | json }},
  "logo": {{ 'gopotty-mark.svg' | asset_url | json }},
  {%- if settings.contact_email != blank -%}
  "email": {{ settings.contact_email | json }},
  {%- endif -%}
  {%- if settings.contact_phone != blank -%}
  "telephone": {{ settings.contact_phone | json }},
  {%- endif -%}
  "sameAs": [
    {%- assign socials = '' -%}
    {%- if settings.social_instagram != blank -%}{%- assign socials = socials | append: settings.social_instagram | append: '|' -%}{%- endif -%}
    {%- if settings.social_tiktok != blank -%}{%- assign socials = socials | append: settings.social_tiktok | append: '|' -%}{%- endif -%}
    {%- if settings.social_facebook != blank -%}{%- assign socials = socials | append: settings.social_facebook | append: '|' -%}{%- endif -%}
    {%- if settings.social_youtube != blank -%}{%- assign socials = socials | append: settings.social_youtube | append: '|' -%}{%- endif -%}
    {%- assign social_arr = socials | split: '|' -%}
    {%- for url in social_arr -%}{% unless url == blank %}{{ url | json }}{% unless forloop.last %},{% endunless %}{% endunless %}{%- endfor -%}
  ]
}
</script>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": {{ shop.name | json }},
  "url": {{ shop.url | json }},
  "potentialAction": {
    "@type": "SearchAction",
    "target": "{{ shop.url }}/search?q={search_term_string}",
    "query-input": "required name=search_term_string"
  }
}
</script>

{%- if request.page_type == 'product' -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Product",
  "name": {{ product.title | json }},
  "description": {{ product.description | strip_html | truncatewords: 60 | json }},
  "image": [{%- for image in product.images limit: 5 -%}{{ image | image_url: width: 1200 | prepend: 'https:' | json }}{%- unless forloop.last -%},{%- endunless -%}{%- endfor -%}],
  "sku": {{ product.selected_or_first_available_variant.sku | json }},
  "brand": {
    "@type": "Brand",
    "name": {{ shop.name | json }}
  },
  "offers": {
    "@type": "Offer",
    "url": "{{ shop.url }}{{ product.url }}",
    "priceCurrency": {{ cart.currency.iso_code | json }},
    "price": {{ product.price | divided_by: 100.0 | json }},
    "availability": "https://schema.org/{% if product.available %}InStock{% else %}OutOfStock{% endif %}",
    "itemCondition": "https://schema.org/NewCondition",
    "seller": {
      "@type": "Organization",
      "name": {{ shop.name | json }}
    }
  },
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "4.9",
    "reviewCount": "1248"
  }
}
</script>
{%- endif -%}

{%- if request.page_type == 'article' -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": {{ article.title | json }},
  "datePublished": "{{ article.published_at | date: '%Y-%m-%dT%H:%M:%SZ' }}",
  "dateModified": "{{ article.updated_at | date: '%Y-%m-%dT%H:%M:%SZ' }}",
  "author": {
    "@type": "Person",
    "name": {{ article.author | json }}
  },
  "publisher": {
    "@type": "Organization",
    "name": {{ shop.name | json }}
  }
  {%- if article.image -%},
  "image": {{ article.image | image_url: width: 1200 | prepend: 'https:' | json }}
  {%- endif -%}
}
</script>
{%- endif -%}

{%- if request.page_type == 'product' or request.page_type == 'collection' or request.page_type == 'article' or request.page_type == 'page' -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": {{ shop.url | json }}
    }{%- if request.page_type == 'product' and product.collections.first -%},
    {
      "@type": "ListItem",
      "position": 2,
      "name": {{ product.collections.first.title | json }},
      "item": "{{ shop.url }}{{ product.collections.first.url }}"
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": {{ product.title | json }},
      "item": "{{ shop.url }}{{ product.url }}"
    }
    {%- elsif request.page_type == 'collection' -%},
    {
      "@type": "ListItem",
      "position": 2,
      "name": {{ collection.title | json }},
      "item": "{{ shop.url }}{{ collection.url }}"
    }
    {%- elsif request.page_type == 'article' -%},
    {
      "@type": "ListItem",
      "position": 2,
      "name": {{ blog.title | json }},
      "item": "{{ shop.url }}{{ blog.url }}"
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": {{ article.title | json }},
      "item": "{{ shop.url }}{{ article.url }}"
    }
    {%- elsif request.page_type == 'page' -%},
    {
      "@type": "ListItem",
      "position": 2,
      "name": {{ page.title | json }},
      "item": "{{ shop.url }}{{ page.url }}"
    }
    {%- endif -%}
  ]
}
</script>
{%- endif -%}
