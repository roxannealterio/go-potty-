{%- comment -%}
  Usage:
    {% render 'logo' %}                       Default header style
    {% render 'logo', size: 'large' %}        Large (popup, hero)
    {% render 'logo', size: 'small' %}        Small
    {% render 'logo', light: true %}          For dark backgrounds (footer)
{%- endcomment -%}

{%- assign size = size | default: 'default' -%}
{%- if size == 'large' -%}
  {%- assign size_class = 'site-logo--large' -%}
{%- elsif size == 'small' -%}
  {%- assign size_class = 'site-logo--small' -%}
{%- else -%}
  {%- assign size_class = '' -%}
{%- endif -%}

{%- if light -%}
  {%- assign light_class = 'site-logo--light' -%}
{%- else -%}
  {%- assign light_class = '' -%}
{%- endif -%}

<span class="site-logo {{ size_class }} {{ light_class }}">
  <span class="site-logo__go">Go</span><span class="site-logo__potty">Potty</span><sup class="site-logo__tm">™</sup>
</span>
