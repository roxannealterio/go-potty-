{% layout 'theme' %}
<section class="product"><div class="page-width" style="max-width:480px;"><h1 class="section-header__title" style="margin-bottom:1.5rem;">Create account</h1>
{% form 'create_customer' %}{{ form.errors | default_errors }}
<input type="text" name="customer[first_name]" placeholder="First name" class="newsletter__input" style="width:100%;margin-bottom:0.75rem;">
<input type="text" name="customer[last_name]" placeholder="Last name" class="newsletter__input" style="width:100%;margin-bottom:0.75rem;">
<input type="email" name="customer[email]" placeholder="Email" class="newsletter__input" required style="width:100%;margin-bottom:0.75rem;">
<input type="password" name="customer[password]" placeholder="Password" class="newsletter__input" required style="width:100%;margin-bottom:1rem;">
<button type="submit" class="btn btn--primary" style="width:100%;">CREATE ACCOUNT</button>
{% endform %}</div></section>
