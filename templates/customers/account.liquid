{% layout 'theme' %}
<section class="product"><div class="page-width"><h1 class="section-header__title" style="text-align:left;margin-bottom:1.5rem;">Hi, {{ customer.first_name }}</h1>
<p><a href="/account/logout">Log out</a></p>
<h2 style="margin-top:2rem;font-family:'Fraunces',serif;">Order history</h2>
{% if customer.orders.size > 0 %}<ul>{% for order in customer.orders %}<li style="padding:0.75rem 0;border-bottom:1px solid var(--color-border);"><a href="{{ order.customer_url }}">Order {{ order.name }}</a> — {{ order.created_at | date: "%b %d, %Y" }} — {{ order.total_price | money }}</li>{% endfor %}</ul>{% else %}<p style="color:var(--color-text-muted);">No orders yet.</p>{% endif %}
</div></section>
