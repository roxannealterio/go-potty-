<!doctype html>
<html><head><meta charset="utf-8"><title>{{ shop.name }}</title>{{ 'base.css' | asset_url | stylesheet_tag }}{{ 'theme.css' | asset_url | stylesheet_tag }}</head>
<body><section style="min-height:100vh;display:flex;align-items:center;justify-content:center;text-align:center;padding:2rem;">
<div><h1 class="hero__title">Opening soon</h1><p style="color:var(--color-text-muted);margin-bottom:2rem;">{{ shop.name }} is launching. Sign up to be the first to know.</p>
{% form 'storefront_password' %}<input type="password" name="password" placeholder="Enter store password" class="newsletter__input"><button class="btn btn--primary" type="submit">ENTER</button>{% endform %}
</div></section></body></html>
