<section class="contact-page">
  <div class="page-width">
    <div class="contact-page__grid">
      <div class="contact-page__intro reveal">
        <span class="eyebrow">{{ section.settings.eyebrow }}</span>
        <h1 class="contact-page__title">{{ section.settings.heading }}</h1>
        <p class="contact-page__text">{{ section.settings.text }}</p>

        <ul class="contact-page__details">
          {% if settings.contact_email != blank %}
            <li>
              <span class="contact-page__detail-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
              </span>
              <div>
                <div class="contact-page__detail-label">Email</div>
                <a href="mailto:{{ settings.contact_email }}">{{ settings.contact_email }}</a>
              </div>
            </li>
          {% endif %}
          {% if settings.contact_phone != blank %}
            <li>
              <span class="contact-page__detail-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              </span>
              <div>
                <div class="contact-page__detail-label">Phone</div>
                <a href="tel:{{ settings.contact_phone | replace: ' ', '' | replace: '-', '' }}">{{ settings.contact_phone }}</a>
              </div>
            </li>
          {% endif %}
          {% if settings.contact_address != blank %}
            <li>
              <span class="contact-page__detail-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
              </span>
              <div>
                <div class="contact-page__detail-label">Address</div>
                <span>{{ settings.contact_address }}</span>
              </div>
            </li>
          {% endif %}
          {% if settings.contact_hours != blank %}
            <li>
              <span class="contact-page__detail-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              </span>
              <div>
                <div class="contact-page__detail-label">Hours</div>
                <span>{{ settings.contact_hours }}</span>
              </div>
            </li>
          {% endif %}
          {% if settings.social_instagram != blank %}
            <li>
              <span class="contact-page__detail-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
              </span>
              <div>
                <div class="contact-page__detail-label">Instagram</div>
                <a href="{{ settings.social_instagram }}" target="_blank" rel="noopener">@{{ settings.social_instagram | split: '/' | last }}</a>
              </div>
            </li>
          {% endif %}
        </ul>
      </div>

      <div class="contact-page__form-wrap reveal">
        {% form 'contact', class: 'contact-page__form' %}
          {% if form.posted_successfully? %}
            <div class="contact-page__success">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
              <h3>Message sent!</h3>
              <p>Thanks for reaching out — we'll get back to you within 24 hours.</p>
            </div>
          {% else %}
            {% if form.errors %}
              <div class="contact-page__error">{{ form.errors | default_errors }}</div>
            {% endif %}
            <h3 class="contact-page__form-heading">Send us a message</h3>
            <div class="contact-page__form-grid">
              <label>
                <span>Name</span>
                <input type="text" name="contact[name]" required>
              </label>
              <label>
                <span>Email</span>
                <input type="email" name="contact[email]" required>
              </label>
            </div>
            <label>
              <span>Subject</span>
              <input type="text" name="contact[subject]">
            </label>
            <label>
              <span>Message</span>
              <textarea name="contact[body]" rows="5" required></textarea>
            </label>
            <button type="submit" class="btn btn--primary">SEND MESSAGE</button>
          {% endif %}
        {% endform %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Contact",
  "settings": [
    { "type": "paragraph", "content": "Contact details are pulled from Theme settings → Contact info." },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "GET IN TOUCH" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "We'd love to hear from you" },
    { "type": "textarea", "id": "text", "label": "Text", "default": "Questions, feedback, or just want to say hi? Our team usually responds within 24 hours." }
  ],
  "presets": [{ "name": "Contact" }]
}
{% endschema %}
