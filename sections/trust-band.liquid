<section class="trust-band">
  <div class="page-width">
    <div class="trust-band__grid">
      {%- for block in section.blocks -%}
        <div class="trust-item" {{ block.shopify_attributes }}>
          <span class="trust-item__icon">
            {% case block.settings.icon %}
              {% when 'leaf' %}
                <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19.2 2.96c1.4 9.3-3.1 17.43-8.2 17.04A7.5 7.5 0 0 1 11 20zM2 21c0-3 1.85-5.36 5.08-6"/></svg>
              {% when 'shield' %}
                <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              {% when 'building' %}
                <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="2" width="16" height="20" rx="2"/><path d="M9 22v-4h6v4"/><path d="M8 6h.01M16 6h.01M8 10h.01M16 10h.01M8 14h.01M16 14h.01M12 6h.01M12 10h.01M12 14h.01"/></svg>
              {% when 'recycle' %}
                <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M7 19H4a2 2 0 0 1-1.73-3l5.74-9.94a2 2 0 0 1 3.46 0L13 9"/><path d="M14 16l-3 3 3 3"/><path d="M11 19h7.5a2.5 2.5 0 0 0 2.16-3.74L19 12"/><path d="M5 10l-2.06.59L4 12.65"/></svg>
              {% when 'truck' %}
                <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M10 17h4V5H2v12h3"/><path d="M20 17h2v-3.34a4 4 0 0 0-1.17-2.83L19 9h-5"/><circle cx="7.5" cy="17.5" r="2.5"/><circle cx="17.5" cy="17.5" r="2.5"/></svg>
              {% when 'return' %}
                <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12a9 9 0 1 0 9-9"/><path d="M3 4v5h5"/></svg>
              {% when 'warranty' %}
                <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M9 12l2 2 4-4"/></svg>
              {% when 'lock' %}
                <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
            {% endcase %}
          </span>
          <div>
            <div class="trust-item__title">{{ block.settings.title }}</div>
            <p class="trust-item__text">{{ block.settings.text }}</p>
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Trust band",
  "settings": [],
  "blocks": [
    {
      "type": "item",
      "name": "Item",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "default": "leaf",
          "options": [
            { "value": "leaf", "label": "Leaf" },
            { "value": "shield", "label": "Shield" },
            { "value": "building", "label": "Building" },
            { "value": "recycle", "label": "Recycle" },
            { "value": "truck", "label": "Truck" },
            { "value": "return", "label": "Return" },
            { "value": "warranty", "label": "Warranty" },
            { "value": "lock", "label": "Lock" }
          ]
        },
        { "type": "text", "id": "title", "label": "Title", "default": "Hygienic & Safe" },
        { "type": "text", "id": "text", "label": "Text", "default": "Keeps your home fresh and clean" }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "Trust band",
      "blocks": [
        { "type": "item", "settings": { "icon": "leaf", "title": "Hygienic & Safe", "text": "Keeps your home fresh and clean" } },
        { "type": "item", "settings": { "icon": "shield", "title": "No More Cleanup", "text": "Hands-free system handles the mess" } },
        { "type": "item", "settings": { "icon": "building", "title": "Perfect for Apartments", "text": "Compact, quiet and discreet design" } },
        { "type": "item", "settings": { "icon": "recycle", "title": "Eco-Friendly", "text": "Uses less water and reduces waste" } }
      ]
    }
  ]
}
{% endschema %}
