<section class="features-section">
  <div class="page-width">
    <div class="features-section__grid">
      <div class="reveal">
        {% if section.settings.eyebrow != blank %}
          <p class="features-section__eyebrow">{{ section.settings.eyebrow }}</p>
        {% endif %}
        <h2 class="features-section__title">{{ section.settings.heading }}</h2>
        <p class="features-section__text">{{ section.settings.text }}</p>
        <a href="{{ section.settings.cta_link }}" class="btn btn--primary">{{ section.settings.cta_text }}</a>
        <div class="features-section__guarantee">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M9 12l2 2 4-4"/></svg>
          <span>{{ section.settings.guarantee_text }}</span>
        </div>
      </div>

      <div class="features-diagram reveal">
        {%- assign left_blocks = section.blocks | where: 'settings.position', 'left' -%}
        {%- assign right_blocks = section.blocks | where: 'settings.position', 'right' -%}

        <div style="display:flex;flex-direction:column;gap:3rem;">
          {%- for block in left_blocks -%}
            <div class="feature-callout feature-callout--left" {{ block.shopify_attributes }}>
              <div class="feature-callout__title">{{ block.settings.title }}</div>
              <p class="feature-callout__text">{{ block.settings.text }}</p>
            </div>
          {%- endfor -%}
        </div>

        {%- if section.settings.image != blank -%}
          <img class="features-diagram__image" src="{{ section.settings.image | image_url: width: 800 }}" alt="{{ section.settings.heading | escape }}" loading="lazy">
        {%- else -%}
          <div class="features-diagram__image">{{ 'product-1' | placeholder_svg_tag }}</div>
        {%- endif -%}

        <div style="display:flex;flex-direction:column;gap:3rem;">
          {%- for block in right_blocks -%}
            <div class="feature-callout feature-callout--right" {{ block.shopify_attributes }}>
              <div class="feature-callout__title">{{ block.settings.title }}</div>
              <p class="feature-callout__text">{{ block.settings.text }}</p>
            </div>
          {%- endfor -%}
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Feature breakdown",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "BUILT FOR MODERN PET PARENTS" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Smart design. Smarter living." },
    { "type": "textarea", "id": "text", "label": "Text", "default": "GoPotty is designed to make pet parenting easier, cleaner and more convenient." },
    { "type": "image_picker", "id": "image", "label": "Product image" },
    { "type": "text", "id": "cta_text", "label": "Button text", "default": "SHOP NOW" },
    { "type": "url", "id": "cta_link", "label": "Button link" },
    { "type": "text", "id": "guarantee_text", "label": "Guarantee text", "default": "14-DAY MONEY-BACK GUARANTEE" }
  ],
  "blocks": [
    {
      "type": "callout",
      "name": "Feature callout",
      "settings": [
        {
          "type": "select", "id": "position", "label": "Position", "default": "left",
          "options": [
            { "value": "left", "label": "Left of image" },
            { "value": "right", "label": "Right of image" }
          ]
        },
        { "type": "text", "id": "title", "label": "Title", "default": "Waste Tank" },
        { "type": "textarea", "id": "text", "label": "Text", "default": "Stores liquid waste in a sealed tank" }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Feature breakdown",
      "blocks": [
        { "type": "callout", "settings": { "position": "left", "title": "Waste Tank", "text": "Stores liquid waste in a sealed tank" } },
        { "type": "callout", "settings": { "position": "left", "title": "Non-Slip Tray", "text": "Comfortable and safe for your dog" } },
        { "type": "callout", "settings": { "position": "right", "title": "Control Panel", "text": "One-touch operation for easy use" } },
        { "type": "callout", "settings": { "position": "right", "title": "Drainage System", "text": "Powerful suction keeps it clean" } }
      ]
    }
  ]
}
{% endschema %}
