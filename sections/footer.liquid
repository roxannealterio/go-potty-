<footer class="site-footer">
  <div class="page-width">
    <div class="site-footer__grid">
      <div>
        <div class="site-footer__logo">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 260 60" style="height:42px;width:auto;" aria-label="GoPotty">
            <g transform="translate(0, 0) scale(0.5)">
              <path d="M60 12 C60 12 50 26 50 34 C50 39.5 54.5 44 60 44 C65.5 44 70 39.5 70 34 C70 26 60 12 60 12 Z" fill="#2BB8B0"/>
              <path d="M30 52 C28 48 30 42 36 42" stroke="#2BB8B0" stroke-width="4.5" stroke-linecap="round" fill="none"/>
              <path d="M36 50 C40 56 46 58 52 58" stroke="#2BB8B0" stroke-width="4.5" stroke-linecap="round" fill="none"/>
              <path d="M90 52 C92 48 90 42 84 42" stroke="#2BB8B0" stroke-width="4.5" stroke-linecap="round" fill="none"/>
              <path d="M84 50 C80 56 74 58 68 58" stroke="#2BB8B0" stroke-width="4.5" stroke-linecap="round" fill="none"/>
              <path d="M46 62 C48 60 52 60 54 62" stroke="#2BB8B0" stroke-width="3" stroke-linecap="round" fill="none"/>
              <circle cx="74" cy="62" r="3" fill="#fff"/>
              <path d="M38 64 C36 76 42 88 52 92 C56 94 64 94 68 92 C78 88 84 76 82 64" stroke="#2BB8B0" stroke-width="4.5" stroke-linecap="round" fill="none"/>
              <ellipse cx="60" cy="76" rx="6" ry="5" fill="#2BB8B0"/>
              <path d="M60 81 L60 86 M60 86 C57 88 54 87 53 85 M60 86 C63 88 66 87 67 85" stroke="#2BB8B0" stroke-width="2.5" stroke-linecap="round" fill="none"/>
            </g>
            <text x="66" y="42" font-family="Inter, sans-serif" font-size="32" font-weight="800" letter-spacing="-1">
              <tspan fill="#2BB8B0">Go</tspan><tspan fill="#fff">Potty</tspan>
            </text>
            <text x="190" y="22" font-family="Inter, sans-serif" font-size="9" fill="#fff">™</text>
          </svg>
        </div>
        <p class="site-footer__tagline">{{ section.settings.tagline }}</p>
        <p class="site-footer__text">{{ section.settings.about_text }}</p>
        <div class="site-footer__social">
          {%- if section.settings.instagram != blank -%}
            <a href="{{ section.settings.instagram }}" aria-label="Instagram" target="_blank" rel="noopener">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
            </a>
          {%- endif -%}
          {%- if section.settings.tiktok != blank -%}
            <a href="{{ section.settings.tiktok }}" aria-label="TikTok" target="_blank" rel="noopener">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-5.2 1.74 2.89 2.89 0 0 1 2.31-4.64 2.93 2.93 0 0 1 .88.13V9.4a6.84 6.84 0 0 0-1-.05A6.33 6.33 0 0 0 5.8 20.1a6.34 6.34 0 0 0 10.86-4.43V8.74a8.16 8.16 0 0 0 4.77 1.52V6.8a4.85 4.85 0 0 1-1.84-.11z"/></svg>
            </a>
          {%- endif -%}
          {%- if section.settings.facebook != blank -%}
            <a href="{{ section.settings.facebook }}" aria-label="Facebook" target="_blank" rel="noopener">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
            </a>
          {%- endif -%}
        </div>
      </div>

      {%- for block in section.blocks -%}
        {%- if block.type == 'menu' -%}
          <div {{ block.shopify_attributes }}>
            <h4 class="site-footer__heading">{{ block.settings.title }}</h4>
            <ul class="site-footer__list">
              {%- if block.settings.menu != blank -%}
                {%- for link in block.settings.menu.links -%}
                  <li><a href="{{ link.url }}">{{ link.title }}</a></li>
                {%- endfor -%}
              {%- endif -%}
            </ul>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

    <div class="site-footer__bottom">
      <div>© {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved.</div>
      <div>{{ section.settings.legal_text }}</div>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    { "type": "text", "id": "tagline", "label": "Tagline", "default": "Smart Potty Solutions" },
    { "type": "textarea", "id": "about_text", "label": "About text", "default": "Engineered to make pet parenting easier. Cleaner homes, happier pets." },
    { "type": "url", "id": "instagram", "label": "Instagram URL" },
    { "type": "url", "id": "tiktok", "label": "TikTok URL" },
    { "type": "url", "id": "facebook", "label": "Facebook URL" },
    { "type": "text", "id": "legal_text", "label": "Legal", "default": "Designed with love." }
  ],
  "blocks": [
    {
      "type": "menu",
      "name": "Menu",
      "settings": [
        { "type": "text", "id": "title", "label": "Title", "default": "Shop" },
        { "type": "link_list", "id": "menu", "label": "Menu" }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [{ "name": "Footer" }]
}
{% endschema %}
