<footer class="site-footer">
  <div class="page-width">
    <div class="site-footer__grid">
      <div class="site-footer__brand">
        <div class="site-footer__logo">
          {% render 'logo', variant: 'horizontal', height: 44, light: true %}
        </div>
        {% if section.settings.tagline != blank %}
          <p class="site-footer__tagline">{{ section.settings.tagline }}</p>
        {% endif %}
        <p class="site-footer__text">{{ section.settings.about_text }}</p>

        {% if settings.contact_email != blank or settings.contact_phone != blank or settings.contact_address != blank %}
          <ul class="site-footer__contact">
            {% if settings.contact_email != blank %}
              <li>
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                <a href="mailto:{{ settings.contact_email }}">{{ settings.contact_email }}</a>
              </li>
            {% endif %}
            {% if settings.contact_phone != blank %}
              <li>
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                <a href="tel:{{ settings.contact_phone | replace: ' ', '' | replace: '-', '' | replace: '(', '' | replace: ')', '' }}">{{ settings.contact_phone }}</a>
              </li>
            {% endif %}
            {% if settings.contact_address != blank %}
              <li>
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                <span>{{ settings.contact_address }}</span>
              </li>
            {% endif %}
          </ul>
        {% endif %}

        <div class="site-footer__social">
          {% if settings.social_instagram != blank %}
            <a href="{{ settings.social_instagram }}" aria-label="Instagram" target="_blank" rel="noopener">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
            </a>
          {% endif %}
          {% if settings.social_tiktok != blank %}
            <a href="{{ settings.social_tiktok }}" aria-label="TikTok" target="_blank" rel="noopener">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-5.2 1.74 2.89 2.89 0 0 1 2.31-4.64 2.93 2.93 0 0 1 .88.13V9.4a6.84 6.84 0 0 0-1-.05A6.33 6.33 0 0 0 5.8 20.1a6.34 6.34 0 0 0 10.86-4.43V8.74a8.16 8.16 0 0 0 4.77 1.52V6.8a4.85 4.85 0 0 1-1.84-.11z"/></svg>
            </a>
          {% endif %}
          {% if settings.social_facebook != blank %}
            <a href="{{ settings.social_facebook }}" aria-label="Facebook" target="_blank" rel="noopener">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M22 12a10 10 0 1 0-11.6 9.87v-6.99H7.9V12h2.5V9.8c0-2.47 1.47-3.83 3.72-3.83 1.08 0 2.21.19 2.21.19v2.43h-1.25c-1.22 0-1.6.76-1.6 1.54V12h2.73l-.44 2.88h-2.29v6.99A10 10 0 0 0 22 12z"/></svg>
            </a>
          {% endif %}
          {% if settings.social_youtube != blank %}
            <a href="{{ settings.social_youtube }}" aria-label="YouTube" target="_blank" rel="noopener">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M23 12s0-3.6-.46-5.32a2.78 2.78 0 0 0-2-2C18.84 4.27 12 4.27 12 4.27s-6.84 0-8.54.41a2.78 2.78 0 0 0-2 2C1 8.4 1 12 1 12s0 3.6.46 5.32a2.78 2.78 0 0 0 2 2c1.7.41 8.54.41 8.54.41s6.84 0 8.54-.41a2.78 2.78 0 0 0 2-2C23 15.6 23 12 23 12zM9.75 15.27V8.73L15.5 12z"/></svg>
            </a>
          {% endif %}
        </div>
      </div>

      {% for block in section.blocks %}
        {% if block.type == 'menu' %}
          <div class="site-footer__col" {{ block.shopify_attributes }}>
            <h4 class="site-footer__heading">{{ block.settings.title }}</h4>
            <ul class="site-footer__list">
              {% if block.settings.menu != blank and block.settings.menu.links.size > 0 %}
                {% for link in block.settings.menu.links %}
                  <li><a href="{{ link.url }}">{{ link.title }}</a></li>
                {% endfor %}
              {% else %}
                {% if block.settings.title == 'Shop' or block.settings.title == 'SHOP' %}
                  <li><a href="/products/gopotty">GoPotty Self-Cleaning Potty</a></li>
                  <li><a href="/collections/all">All Products</a></li>
                  <li><a href="/collections/accessories">Accessories</a></li>
                  <li><a href="/pages/replacement-parts">Replacement Parts</a></li>
                {% elsif block.settings.title == 'Support' or block.settings.title == 'SUPPORT' %}
                  <li><a href="/pages/contact">Contact Us</a></li>
                  <li><a href="/pages/shipping-policy">Shipping Policy</a></li>
                  <li><a href="/pages/refund-policy">Refund & Returns</a></li>
                  <li><a href="/pages/faq">FAQ</a></li>
                {% else %}
                  <li><a href="/pages/about">About Us</a></li>
                  <li><a href="/blogs/news">Blog</a></li>
                  <li><a href="/pages/privacy-policy">Privacy Policy</a></li>
                  <li><a href="/pages/terms-of-service">Terms of Service</a></li>
                {% endif %}
              {% endif %}
            </ul>
          </div>
        {% endif %}
      {% endfor %}
    </div>

    <div class="site-footer__bottom">
      <div class="site-footer__bottom-left">
        <span>© {{ 'now' | date: '%Y' }} {{ shop.name }}. {{ section.settings.legal_text }}</span>
      </div>
      <div class="site-footer__payments" aria-label="Payment methods">
        {% for type in shop.enabled_payment_types %}
          {{ type | payment_type_svg_tag: class: 'site-footer__payment-icon' }}
        {% else %}
          <span class="site-footer__payment-fallback">VISA</span>
          <span class="site-footer__payment-fallback">MC</span>
          <span class="site-footer__payment-fallback">AMEX</span>
          <span class="site-footer__payment-fallback">PAYPAL</span>
          <span class="site-footer__payment-fallback">AFTERPAY</span>
        {% endfor %}
      </div>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    { "type": "paragraph", "content": "Contact info and social URLs are managed in Theme settings → Contact info / Social so they apply site-wide." },
    { "type": "text", "id": "tagline", "label": "Tagline", "default": "Smart Potty Solutions" },
    { "type": "textarea", "id": "about_text", "label": "About text", "default": "Engineered to make pet parenting easier. Cleaner homes, happier pets." },
    { "type": "text", "id": "legal_text", "label": "Legal text", "default": "All rights reserved." }
  ],
  "blocks": [
    {
      "type": "menu",
      "name": "Menu column",
      "settings": [
        { "type": "text", "id": "title", "label": "Title", "default": "Shop" },
        { "type": "link_list", "id": "menu", "label": "Menu (optional)" }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "Footer",
      "blocks": [
        { "type": "menu", "settings": { "title": "Shop" } },
        { "type": "menu", "settings": { "title": "Support" } },
        { "type": "menu", "settings": { "title": "Company" } }
      ]
    }
  ]
}
{% endschema %}
