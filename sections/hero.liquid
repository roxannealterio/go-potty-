<section class="hero">
  <div class="page-width">
    <div class="hero__grid">
      <div class="hero__content reveal">
        {% if section.settings.eyebrow != blank %}
          <span class="eyebrow">{{ section.settings.eyebrow }}</span>
        {% endif %}
        <h1 class="hero__title">{{ section.settings.heading }}</h1>
        <p class="hero__subtitle">{{ section.settings.subheading }}</p>

        <div class="hero__features">
          {%- for block in section.blocks -%}
            <div class="hero__feature" {{ block.shopify_attributes }}>
              <span class="hero__feature-icon">
                {% case block.settings.icon %}
                  {% when 'suction' %}
                    <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg>
                  {% when 'water' %}
                    <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2.69l5.66 5.66a8 8 0 1 1-11.31 0z"/></svg>
                  {% when 'odor' %}
                    <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"><path d="M8 4c0 4 4 4 4 8M12 4c0 4 4 4 4 8M16 4c0 4 4 4 4 8M4 4c0 4 4 4 4 8"/><path d="M3 16h18M3 20h18"/></svg>
                  {% when 'touch' %}
                    <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M9 12l2 2 4-4"/></svg>
                  {% else %}
                    <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><circle cx="12" cy="12" r="9"/></svg>
                {% endcase %}
              </span>
              <span class="hero__feature-label">{{ block.settings.label }}</span>
            </div>
          {%- endfor -%}
        </div>

        <div class="hero__cta-row">
          <a href="{{ section.settings.cta_link }}" class="btn btn--primary">{{ section.settings.cta_text }}</a>
          {% if section.settings.video_url != blank %}
            <a href="{{ section.settings.video_url }}" class="hero__video-link" target="_blank" rel="noopener">
              <span class="hero__video-link-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
              </span>
              <span>{{ section.settings.video_text }}</span>
            </a>
          {% endif %}
        </div>
      </div>

      <div class="hero__image-wrap reveal">
        {%- if section.settings.image != blank -%}
          <img class="hero__image" src="{{ section.settings.image | image_url: width: 1200 }}" alt="{{ section.settings.heading | escape }}" loading="eager" width="{{ section.settings.image.width }}" height="{{ section.settings.image.height }}">
        {%- else -%}
          {{ 'lifestyle-1' | placeholder_svg_tag: 'hero__image' }}
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow text", "default": "A SMARTER WAY TO POTTY" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "The Self-Cleaning Dog Potty" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Automatically drains, collects and stores urine so you never have to clean it up again." },
    { "type": "image_picker", "id": "image", "label": "Hero image" },
    { "type": "text", "id": "cta_text", "label": "CTA text", "default": "SHOP NOW" },
    { "type": "url", "id": "cta_link", "label": "CTA link" },
    { "type": "url", "id": "video_url", "label": "Video URL" },
    { "type": "text", "id": "video_text", "label": "Video link text", "default": "WATCH VIDEO" }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "default": "suction",
          "options": [
            { "value": "suction", "label": "Suction" },
            { "value": "water", "label": "Water drop" },
            { "value": "odor", "label": "Odor control" },
            { "value": "touch", "label": "One-touch" }
          ]
        },
        { "type": "text", "id": "label", "label": "Label", "default": "Auto Suction System" }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Hero",
      "blocks": [
        { "type": "feature", "settings": { "icon": "suction", "label": "Auto Suction System" } },
        { "type": "feature", "settings": { "icon": "water", "label": "Rinse & Clean in Seconds" } },
        { "type": "feature", "settings": { "icon": "odor", "label": "Odor Control Technology" } },
        { "type": "feature", "settings": { "icon": "touch", "label": "Easy to Use One-Touch" } }
      ]
    }
  ]
}
{% endschema %}
