{%- if section.settings.enabled -%}
<div class="popup" data-popup data-popup-delay="{{ section.settings.delay | times: 1000 }}" data-popup-trigger="{{ section.settings.trigger }}" aria-hidden="true" role="dialog" aria-labelledby="popup-heading">
  <div class="popup__backdrop" data-popup-close></div>
  <div class="popup__panel">
    <button class="popup__close" data-popup-close aria-label="Close popup">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>

    <div class="popup__visual">
      {%- if section.settings.image != blank -%}
        <img src="{{ section.settings.image | image_url: width: 800 }}" alt="" loading="lazy">
      {%- else -%}
        <div class="popup__mark">
          {% render 'logo', size: 'large' %}
        </div>
      {%- endif -%}
    </div>

    <div class="popup__content">
      <span class="popup__eyebrow">{{ section.settings.eyebrow }}</span>
      <h2 class="popup__heading" id="popup-heading">{{ section.settings.heading }}</h2>
      <p class="popup__text">{{ section.settings.text }}</p>

      {% form 'customer', class: 'popup__form' %}
        <input type="hidden" name="contact[tags]" value="newsletter, popup">
        <div class="popup__form-row">
          <input type="email" name="contact[email]" placeholder="{{ section.settings.placeholder }}" required aria-label="Email">
          <button type="submit" class="btn btn--primary">{{ section.settings.button_text }}</button>
        </div>
        {%- if form.posted_successfully? -%}
          <p class="popup__success">✓ {{ section.settings.success_text }}</p>
        {%- endif -%}
        {%- if form.errors -%}
          <p class="popup__error">{{ form.errors.messages.email }}</p>
        {%- endif -%}
      {% endform %}

      <button class="popup__dismiss" data-popup-close>{{ section.settings.dismiss_text }}</button>
    </div>
  </div>
</div>
{%- endif -%}

{% schema %}
{
  "name": "Newsletter popup",
  "settings": [
    { "type": "checkbox", "id": "enabled", "label": "Enable popup", "default": true },
    {
      "type": "select",
      "id": "trigger",
      "label": "Trigger",
      "default": "delay",
      "options": [
        { "value": "delay", "label": "After delay" },
        { "value": "exit", "label": "Exit intent + delay" },
        { "value": "scroll", "label": "After scrolling 50%" }
      ]
    },
    { "type": "range", "id": "delay", "label": "Delay (seconds)", "min": 3, "max": 30, "step": 1, "default": 8 },
    { "type": "header", "content": "Content" },
    { "type": "image_picker", "id": "image", "label": "Image (optional)" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "JOIN THE PACK" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Get 10% off your first order" },
    { "type": "textarea", "id": "text", "label": "Text", "default": "Plus smart pet-parenting tips, exclusive launches, and a happier home — straight to your inbox." },
    { "type": "text", "id": "placeholder", "label": "Email placeholder", "default": "Your email address" },
    { "type": "text", "id": "button_text", "label": "Button text", "default": "CLAIM 10% OFF" },
    { "type": "text", "id": "dismiss_text", "label": "Dismiss link text", "default": "No thanks, I'll pay full price" },
    { "type": "text", "id": "success_text", "label": "Success message", "default": "Welcome to the pack! Check your email for your code." }
  ],
  "presets": [{ "name": "Newsletter popup" }]
}
{% endschema %}
