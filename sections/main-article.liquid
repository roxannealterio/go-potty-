<article class="product" style="padding-top:3rem;">
  <div class="page-width" style="max-width:760px;">
    <p class="eyebrow" style="margin-bottom:1rem;">{{ article.published_at | date: "%b %d, %Y" }}</p>
    <h1 class="section-header__title" style="text-align:left;margin-bottom:1.5rem;">{{ article.title }}</h1>
    {%- if article.image -%}
      <img src="{{ article.image | image_url: width: 1400 }}" alt="{{ article.title | escape }}" style="width:100%;border-radius:14px;margin-bottom:2rem;">
    {%- endif -%}
    <div class="rte" style="line-height:1.7;">{{ article.content }}</div>
  </div>
</article>
{% schema %}
{ "name": "Article", "settings": [] }
{% endschema %}
