<section class="product">
  <div class="page-width">
    <div class="product__grid">
      <div class="product__media">
        {%- assign featured_image = product.featured_image | default: product.images.first -%}
        <div class="product__media-main">
          {%- if featured_image != blank -%}
            <img data-main-image src="{{ featured_image | image_url: width: 1200 }}" alt="{{ featured_image.alt | default: product.title | escape }}" width="800" height="800">
          {%- else -%}
            {{ 'product-1' | placeholder_svg_tag }}
          {%- endif -%}
        </div>
        {%- if product.images.size > 1 -%}
          <div class="product__thumbs">
            {%- for image in product.images -%}
              <button class="product__thumb {% if forloop.first %}is-active{% endif %}" type="button" data-thumb data-fullsrc="{{ image | image_url: width: 1200 }}" aria-label="View image {{ forloop.index }}">
                <img src="{{ image | image_url: width: 160 }}" alt="" width="80" height="80" loading="lazy">
              </button>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>

      <div class="product__info">
        <span class="eyebrow">{{ section.settings.eyebrow | default: 'NEW ARRIVAL' }}</span>
        <h1 class="product__title">{{ product.title }}</h1>

        <div class="product__rating">
          <span class="stars">
            {% for i in (1..5) %}
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l2.39 7.36H22l-6.18 4.49L18.21 22 12 17.36 5.79 22l2.39-8.15L2 9.36h7.61z"/></svg>
            {% endfor %}
          </span>
          <span>4.9 · 1,248 reviews</span>
        </div>

        <div class="product__price-row">
          <span class="product__price">{{ product.price | money }}</span>
          {%- if product.compare_at_price > product.price -%}
            <span class="product__price--compare">{{ product.compare_at_price | money }}</span>
            {%- assign savings = product.compare_at_price | minus: product.price | times: 100.0 | divided_by: product.compare_at_price | round -%}
            <span class="product__savings">Save {{ savings }}%</span>
          {%- endif -%}
        </div>

        <div class="product__description">
          {%- if product.description != blank -%}
            {{ product.description }}
          {%- else -%}
            <p>Say goodbye to indoor accidents and constant cleaning. GoPotty's self-rinsing tray and sealed waste system handle the mess automatically — so you can focus on the cuddles, not the cleanup.</p>
          {%- endif -%}
        </div>

        <form method="post" action="/cart/add" id="product-form" class="product-form" enctype="multipart/form-data">
          {%- if product.has_only_default_variant == false -%}
            {%- for option in product.options_with_values -%}
              <label class="product__variant-label">{{ option.name }}</label>
              <div class="variant-options" data-variant-group>
                {%- for value in option.values -%}
                  {%- assign variant = product.variants[forloop.index0] -%}
                  <button type="button" class="variant-option {% if forloop.first %}is-active{% endif %}" data-variant-id="{{ variant.id }}">{{ value }}</button>
                {%- endfor -%}
              </div>
            {%- endfor -%}
          {%- endif -%}

          <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}" data-variant-input>

          <div class="quantity-row">
            <label class="product__variant-label" style="margin:0;">Quantity</label>
            <div class="quantity-input" data-quantity>
              <button type="button" data-qty-minus aria-label="Decrease quantity">−</button>
              <input type="number" name="quantity" value="1" min="1" aria-label="Quantity">
              <button type="button" data-qty-plus aria-label="Increase quantity">+</button>
            </div>
          </div>

          <button type="submit" class="btn btn--primary product__cta" {% unless product.available %}disabled{% endunless %}>
            {%- if product.available -%}
              ADD TO CART — {{ product.selected_or_first_available_variant.price | money }}
            {%- else -%}
              SOLD OUT
            {%- endif -%}
          </button>
          <button type="submit" name="checkout" class="btn product__buy-now" {% unless product.available %}disabled{% endunless %}>BUY IT NOW</button>
        </form>

        <div class="product__benefits">
          <div class="product__benefit">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 17h4V5H2v12h3"/><path d="M20 17h2v-3.34a4 4 0 0 0-1.17-2.83L19 9h-5"/><circle cx="7.5" cy="17.5" r="2.5"/><circle cx="17.5" cy="17.5" r="2.5"/></svg>
            <span>Free shipping over $99</span>
          </div>
          <div class="product__benefit">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12a9 9 0 1 0 9-9"/><path d="M3 4v5h5"/></svg>
            <span>30-day money-back guarantee</span>
          </div>
          <div class="product__benefit">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M9 12l2 2 4-4"/></svg>
            <span>1-year limited warranty</span>
          </div>
          <div class="product__benefit">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
            <span>Secure SSL checkout</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Product",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow above title", "default": "BEST-SELLER" }
  ]
}
{% endschema %}
