<section class="faq-section">
  <div class="page-width">
    <header class="section-header reveal">
      <h2 class="section-header__title">{{ section.settings.heading }}</h2>
      {% if section.settings.subheading != blank %}
        <p class="section-header__subtitle">{{ section.settings.subheading }}</p>
      {% endif %}
    </header>

    <div class="faq-list">
      {%- for block in section.blocks -%}
        <div class="faq-item" {{ block.shopify_attributes }}>
          <button class="faq-item__question" type="button" aria-expanded="false">
            <span>{{ block.settings.question }}</span>
            <span class="faq-item__icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            </span>
          </button>
          <div class="faq-item__answer">
            <div style="padding-bottom:1rem;">{{ block.settings.answer }}</div>
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "FAQ",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Frequently Asked Questions" },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "Everything you need to know about GoPotty" }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "Question",
      "settings": [
        { "type": "text", "id": "question", "label": "Question", "default": "How does the self-cleaning system work?" },
        { "type": "textarea", "id": "answer", "label": "Answer", "default": "When your dog uses the tray, liquid drains through the non-slip surface and is automatically suctioned into a sealed waste tank. You just empty the tank and rinse the tray with water." }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [
    {
      "name": "FAQ",
      "blocks": [
        { "type": "faq", "settings": { "question": "How does the self-cleaning system work?", "answer": "When your dog uses the tray, liquid drains through the non-slip surface and is automatically suctioned into a sealed waste tank. You just empty the tank and rinse the tray with water." } },
        { "type": "faq", "settings": { "question": "Is it suitable for all dog breeds?", "answer": "GoPotty is designed for small to medium breeds up to 40 lbs. The non-slip surface is comfortable for paws of all sizes." } },
        { "type": "faq", "settings": { "question": "How often do I need to empty the waste tank?", "answer": "The sealed waste tank holds up to a week of typical use for a small dog. We recommend emptying it every 5-7 days for optimal hygiene." } },
        { "type": "faq", "settings": { "question": "What's included in the box?", "answer": "Each GoPotty comes with the base unit, removable tray, waste tank, power adapter, and a quick-start guide." } },
        { "type": "faq", "settings": { "question": "What's your return policy?", "answer": "We offer a 30-day money-back guarantee. If you're not completely satisfied, send it back for a full refund." } }
      ]
    }
  ]
}
{% endschema %}
