<section class="product" style="padding-top:3rem;">
  <div class="page-width">
    <header class="section-header reveal" style="text-align:left;margin-bottom:2.5rem;">
      <h1 class="section-header__title">{{ collection.title }}</h1>
      {% if collection.description != blank %}
        <p class="section-header__subtitle" style="max-width:600px;">{{ collection.description }}</p>
      {% endif %}
    </header>
    <div class="steps-grid">
      {%- for product in collection.products -%}
        <a href="{{ product.url }}" class="step" style="text-decoration:none;color:inherit;">
          <div class="step__image-wrap">
            {%- if product.featured_image -%}
              <img class="step__image" src="{{ product.featured_image | image_url: width: 800 }}" alt="{{ product.title | escape }}" loading="lazy">
            {%- else -%}
              {{ 'product-1' | placeholder_svg_tag: 'step__image' }}
            {%- endif -%}
          </div>
          <h3 class="step__title">{{ product.title }}</h3>
          <p class="step__text">{{ product.price | money }}</p>
        </a>
      {%- else -%}
        <p>No products yet.</p>
      {%- endfor -%}
    </div>
  </div>
</section>
{% schema %}
{ "name": "Collection", "settings": [] }
{% endschema %}
