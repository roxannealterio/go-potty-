<section class="product" style="padding-top:3rem;">
  <div class="page-width">
    <h1 class="section-header__title" style="text-align:left;margin-bottom:1rem;">Search</h1>
    <form action="/search" method="get" style="margin-bottom:2.5rem;">
      <input type="search" name="q" value="{{ search.terms | escape }}" placeholder="Search…" class="newsletter__input" style="width:100%;max-width:480px;">
    </form>
    {%- if search.performed -%}
      <p style="margin-bottom:2rem;color:var(--color-text-muted);">{{ search.results_count }} results for "{{ search.terms }}"</p>
      <div class="steps-grid">
        {%- for item in search.results -%}
          <a href="{{ item.url }}" class="step" style="text-decoration:none;color:inherit;">
            <h3 class="step__title">{{ item.title }}</h3>
            <p class="step__text">{{ item.content | strip_html | truncatewords: 20 }}</p>
          </a>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>
{% schema %}
{ "name": "Search", "settings": [] }
{% endschema %}
