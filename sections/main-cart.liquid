<section class="cart-page">
  <div class="page-width">
    <h1 class="cart-page__title">Your cart</h1>
    {%- if cart.item_count > 0 -%}
      <p class="cart-page__subtitle">{{ cart.item_count }} {% if cart.item_count == 1 %}item{% else %}items{% endif %} ready for checkout.</p>

      <div class="cart-page__layout">
        <form action="{{ routes.cart_url }}" method="post" id="cart-form">
          <div class="cart-lines">
            {%- for item in cart.items -%}
              <div class="cart-line" data-cart-line="{{ item.key }}">
                <a href="{{ item.url }}" class="cart-line__image" aria-label="{{ item.product.title | escape }}">
                  {%- if item.image -%}
                    <img src="{{ item.image | image_url: width: 200 }}" alt="{{ item.title | escape }}" loading="lazy" width="100" height="100">
                  {%- endif -%}
                </a>
                <div>
                  <div class="cart-line__title"><a href="{{ item.url }}">{{ item.product.title }}</a></div>
                  {%- unless item.variant.title == 'Default Title' -%}
                    <div class="cart-line__variant">{{ item.variant.title }}</div>
                  {%- endunless -%}
                  <div class="cart-line__price">{{ item.final_price | money }}</div>
                  <div class="quantity-input" data-quantity>
                    <button type="button" data-qty-minus aria-label="Decrease">−</button>
                    <input type="number" name="updates[{{ item.key }}]" value="{{ item.quantity }}" min="0" aria-label="Quantity">
                    <button type="button" data-qty-plus aria-label="Increase">+</button>
                  </div>
                  <a href="{{ item.url_to_remove }}" class="cart-line__remove" style="margin-top:0.75rem;display:inline-block;">Remove</a>
                </div>
                <div class="cart-line__total">{{ item.final_line_price | money }}</div>
              </div>
            {%- endfor -%}
          </div>

          {%- comment -%} ===== UPSELL WIDGET ===== {%- endcomment -%}
          {%- if section.settings.upsell_enabled -%}
            {%- assign upsell_handle = section.settings.upsell_product -%}
            {%- if upsell_handle != blank -%}
              {%- assign upsell_product = all_products[upsell_handle] -%}
              {%- if upsell_product != blank and upsell_product != empty -%}
                {%- comment -%} Check if upsell is already in cart {%- endcomment -%}
                {%- assign already_added = false -%}
                {%- for item in cart.items -%}
                  {%- if item.product.handle == upsell_handle -%}
                    {%- assign already_added = true -%}
                  {%- endif -%}
                {%- endfor -%}

                {%- unless already_added -%}
                  <div class="cart-upsell">
                    <span class="cart-upsell__badge">{{ section.settings.upsell_badge }}</span>
                    <h3 class="cart-upsell__heading">{{ section.settings.upsell_heading }}</h3>
                    <p class="cart-upsell__text">{{ section.settings.upsell_text }}</p>

                    <div class="cart-upsell__product">
                      <div class="cart-upsell__image">
                        {%- if upsell_product.featured_image -%}
                          <img src="{{ upsell_product.featured_image | image_url: width: 160 }}" alt="{{ upsell_product.title | escape }}" loading="lazy">
                        {%- endif -%}
                      </div>
                      <div class="cart-upsell__details">
                        <div class="cart-upsell__product-title">{{ upsell_product.title }}</div>
                        <div class="cart-upsell__product-meta">{{ upsell_product.description | strip_html | truncatewords: 12 }}</div>
                        <div class="cart-upsell__price-row">
                          <span class="cart-upsell__price">{{ upsell_product.price | money }}</span>
                          {%- if upsell_product.compare_at_price > upsell_product.price -%}
                            <span class="cart-upsell__price-compare">{{ upsell_product.compare_at_price | money }}</span>
                          {%- endif -%}
                        </div>
                      </div>
                      <form action="/cart/add" method="post" enctype="multipart/form-data" class="cart-upsell__add-form">
                        <input type="hidden" name="id" value="{{ upsell_product.selected_or_first_available_variant.id }}">
                        <input type="hidden" name="quantity" value="1">
                        <button type="submit" class="cart-upsell__add" {% unless upsell_product.available %}disabled{% endunless %}>
                          {%- if upsell_product.available -%}
                            + ADD
                          {%- else -%}
                            SOLD OUT
                          {%- endif -%}
                        </button>
                      </form>
                    </div>
                  </div>
                {%- endunless -%}

              {%- else -%}
                {%- comment -%} Fallback: product handle is set but product doesn't exist yet (e.g. before user creates it). Show a styled placeholder so they know where it'll appear. {%- endcomment -%}
                <div class="cart-upsell">
                  <span class="cart-upsell__badge">{{ section.settings.upsell_badge }}</span>
                  <h3 class="cart-upsell__heading">{{ section.settings.upsell_heading }}</h3>
                  <p class="cart-upsell__text">Create a product with the handle "<strong>{{ upsell_handle }}</strong>" in Shopify Admin and it'll show up here automatically.</p>
                </div>
              {%- endif -%}
            {%- endif -%}
          {%- endif -%}
        </form>

        <aside class="cart-summary">
          <div class="cart-summary__heading">Order summary</div>
          <div class="cart-summary__row">
            <span>Subtotal</span>
            <span>{{ cart.items_subtotal_price | money }}</span>
          </div>
          {%- if cart.total_discount > 0 -%}
            <div class="cart-summary__row" style="color:var(--color-accent-dark);">
              <span>Discount</span>
              <span>−{{ cart.total_discount | money }}</span>
            </div>
          {%- endif -%}
          <div class="cart-summary__row" style="color:var(--color-text-muted);font-size:0.8125rem;">
            <span>Shipping</span>
            <span>Calculated at checkout</span>
          </div>

          <div class="cart-summary__total">
            <span class="cart-summary__total-label">Total</span>
            <span class="cart-summary__total-amount">{{ cart.total_price | money }}</span>
          </div>

          {%- assign threshold = 9900 -%}
          {%- if cart.total_price < threshold -%}
            {%- assign remaining = threshold | minus: cart.total_price -%}
            <p style="font-size:0.8125rem;color:var(--color-accent-dark);background:var(--color-accent-light);padding:0.75rem;border-radius:8px;margin-bottom:1rem;text-align:center;">
              You're {{ remaining | money }} away from free shipping!
            </p>
          {%- else -%}
            <p style="font-size:0.8125rem;color:var(--color-accent-dark);background:var(--color-accent-light);padding:0.75rem;border-radius:8px;margin-bottom:1rem;text-align:center;">
              ✓ Free shipping unlocked
            </p>
          {%- endif -%}

          <button type="submit" form="cart-form" name="checkout" class="btn btn--primary cart-summary__checkout">
            CHECKOUT
          </button>
          <button type="submit" form="cart-form" name="update" class="btn btn--ghost" style="width:100%;">
            UPDATE CART
          </button>
          <p class="cart-summary__note">Taxes calculated at checkout · Secure SSL payment</p>
        </aside>
      </div>
    {%- else -%}
      <div class="cart-empty">
        <div class="cart-empty__icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
        </div>
        <h2 style="font-size:1.5rem;margin-bottom:0.5rem;">Your cart is empty</h2>
        <p>Add a GoPotty to get started.</p>
        <a href="/products/gopotty" class="btn btn--primary">SHOP GOPOTTY</a>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Cart",
  "settings": [
    { "type": "header", "content": "Upsell widget" },
    { "type": "checkbox", "id": "upsell_enabled", "label": "Show upsell widget on cart", "default": true },
    { "type": "text", "id": "upsell_product", "label": "Upsell product handle", "default": "fake-grass-overlay", "info": "The product's URL handle, e.g. 'fake-grass-overlay'. Won't show if the upsell is already in cart." },
    { "type": "text", "id": "upsell_badge", "label": "Badge text", "default": "PERFECT MATCH" },
    { "type": "text", "id": "upsell_heading", "label": "Heading", "default": "Complete your setup" },
    { "type": "textarea", "id": "upsell_text", "label": "Description", "default": "Add a realistic fake grass overlay for a more natural feel your dog will love. Snaps right on, easy to rinse." }
  ],
  "presets": [{ "name": "Cart" }]
}
{% endschema %}
