<section class="product" style="padding-top:3rem;">
  <div class="page-width">
    <h1 class="section-header__title" style="margin-bottom:2rem;">Your Cart</h1>
    {%- if cart.item_count > 0 -%}
      <form action="/cart" method="post">
        {%- for item in cart.items -%}
          <div style="display:flex;gap:1.5rem;padding:1.5rem 0;border-bottom:1px solid var(--color-border);align-items:center;">
            <a href="{{ item.url }}" style="flex-shrink:0;width:100px;height:100px;border-radius:8px;overflow:hidden;background:var(--color-bg-alt);">
              {%- if item.image -%}<img src="{{ item.image | image_url: width: 200 }}" alt="{{ item.title | escape }}" style="width:100%;height:100%;object-fit:cover;">{%- endif -%}
            </a>
            <div style="flex:1;">
              <a href="{{ item.url }}" style="font-weight:600;color:inherit;">{{ item.product.title }}</a>
              {%- if item.variant.title != 'Default Title' -%}<div style="color:var(--color-text-muted);font-size:0.875rem;">{{ item.variant.title }}</div>{%- endif -%}
              <div style="margin-top:0.5rem;font-weight:600;">{{ item.final_line_price | money }}</div>
            </div>
            <div class="quantity-input" data-quantity>
              <a href="{{ item.url_to_remove }}" aria-label="Remove" style="padding:0 0.75rem;color:var(--color-text-muted);">×</a>
              <input type="number" name="updates[]" value="{{ item.quantity }}" min="0" aria-label="Quantity">
            </div>
          </div>
        {%- endfor -%}
        <div style="display:flex;justify-content:space-between;align-items:center;padding-top:2rem;flex-wrap:wrap;gap:1rem;">
          <div style="font-size:1.25rem;font-weight:600;">Subtotal: {{ cart.total_price | money }}</div>
          <div style="display:flex;gap:0.75rem;">
            <button type="submit" name="update" class="btn btn--ghost">UPDATE</button>
            <button type="submit" name="checkout" class="btn btn--primary">CHECKOUT</button>
          </div>
        </div>
      </form>
    {%- else -%}
      <p style="color:var(--color-text-muted);">Your cart is empty. <a href="/collections/all" style="text-decoration:underline;">Start shopping</a>.</p>
    {%- endif -%}
  </div>
</section>
{% schema %}
{ "name": "Cart", "settings": [] }
{% endschema %}
