<section class="reviews-section">
  <div class="page-width">
    <header class="reviews-section__header reveal">
      <h2 class="reviews-section__title">{{ section.settings.heading }}</h2>
      <div class="reviews-section__rating">
        <span class="stars">
          {% for i in (1..5) %}
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l2.39 7.36H22l-6.18 4.49L18.21 22 12 17.36 5.79 22l2.39-8.15L2 9.36h7.61z"/></svg>
          {% endfor %}
        </span>
        <span>{{ section.settings.rating_text }}</span>
      </div>
    </header>

    <div class="reviews-grid">
      {%- for block in section.blocks -%}
        <article class="review-card reveal" {{ block.shopify_attributes }}>
          <div class="review-card__head">
            <div class="review-card__person">
              <div class="review-card__avatar">
                {%- if block.settings.avatar != blank -%}
                  <img src="{{ block.settings.avatar | image_url: width: 80 }}" alt="{{ block.settings.name | escape }}" width="40" height="40" loading="lazy">
                {%- else -%}
                  {{ 'image' | placeholder_svg_tag }}
                {%- endif -%}
              </div>
              <div>
                <div class="review-card__name">{{ block.settings.name }}</div>
                <div class="review-card__verified">{{ block.settings.verified_text }}</div>
              </div>
            </div>
            <span class="stars">
              {% for i in (1..5) %}
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l2.39 7.36H22l-6.18 4.49L18.21 22 12 17.36 5.79 22l2.39-8.15L2 9.36h7.61z"/></svg>
              {% endfor %}
            </span>
          </div>
          <p class="review-card__body">{{ block.settings.text }}</p>
        </article>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Reviews",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Loved by Pets. Trusted by Parents." },
    { "type": "text", "id": "rating_text", "label": "Rating text", "default": "4.9/5 from 1,248+ customers" }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        { "type": "image_picker", "id": "avatar", "label": "Avatar" },
        { "type": "text", "id": "name", "label": "Name", "default": "Jessica L." },
        { "type": "text", "id": "verified_text", "label": "Subtext", "default": "Verified Buyer" },
        { "type": "textarea", "id": "text", "label": "Review text", "default": "Game changer! No more cleaning up accidents or constant washing. GoPotty keeps my apartment smelling fresh." }
      ]
    }
  ],
  "max_blocks": 9,
  "presets": [
    {
      "name": "Reviews",
      "blocks": [
        { "type": "review", "settings": { "name": "Jessica L.", "text": "Game changer! No more cleaning up accidents or constant washing. GoPotty keeps my apartment smelling fresh." } },
        { "type": "review", "settings": { "name": "Daniel M.", "text": "The auto suction system works perfectly. It's so easy to use and keeps my home clean and odor-free." } },
        { "type": "review", "settings": { "name": "Sophia K.", "text": "My puppy took to it right away. The best purchase I've made for apartment living!" } }
      ]
    }
  ]
}
{% endschema %}
